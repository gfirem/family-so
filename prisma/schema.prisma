// family-so data model — direct translation of docs/ARCHITECTURE.md.
// Designed so the couple SHARES the same data; `ownerId` lets habits and
// weight be individual. Prisma 7 (Rust-free) + pg driver adapter.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Family: groups the members and owns the shared (public) plannings. ---
// Singleton today (the couple), but modeled so more members/options can be added.
model Family {
  id        String   @id @default(cuid())
  name      String   @default("Mi familia")
  image     String? // family photo (URL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
  weeks   Week[]
}

// --- People: Guille and China. Sign in with Google Workspace. ---
model User {
  id        String   @id @default(cuid())
  name      String // "Guille" / "China"
  email     String   @unique
  image     String? // Google profile picture
  role      String   @default("member")
  createdAt DateTime @default(now())

  familyId String?
  family   Family? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  habits     Habit[]
  habitLogs  HabitLog[]
  weightLogs WeightLog[]
  weeks      Week[]     @relation("OwnedWeeks") // plannings this person owns (private)
}

// --- The 12 pillars of life. ---
model Pillar {
  id     String  @id @default(cuid())
  name   String  @unique
  order  Int     @default(0)
  active Boolean @default(true)

  goals Goal[]
}

// --- Quarterly goals assigned to a pillar. ---
model Goal {
  id        String     @id @default(cuid())
  year      Int
  quarter   Int // 1..4
  pillarId  String
  pillar    Pillar     @relation(fields: [pillarId], references: [id])
  text      String
  status    GoalStatus @default(open)
  createdAt DateTime   @default(now())
  closedAt  DateTime?

  @@index([year, quarter])
}

enum GoalStatus {
  open
  done
  carried // carried over to the next quarter
}

// --- Individual habits (per person). ---
model Habit {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  identityLink String? // e.g. "soy alguien que duerme bien"
  isKeystone   Boolean  @default(false)
  order        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  logs HabitLog[]

  @@index([ownerId, active])
}

// --- Daily log for each habit. Streak and total are derived from here. ---
model HabitLog {
  id      String   @id @default(cuid())
  habitId String
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  ownerId String
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date
  done    Boolean  @default(true)

  @@unique([habitId, date])
  @@index([ownerId, date])
}

// --- Weekly weight, individual. ---
model WeightLog {
  id      String   @id @default(cuid())
  ownerId String
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date
  weightKg Float

  @@unique([ownerId, date])
  @@index([ownerId, date])
}

// --- Day structure + sleep rules (config, not per day). Singleton. ---
model DayStructure {
  id         String   @id @default(cuid())
  blocks     Json // [{ time, label, items[] }] — morning chain, schedules
  sleepRules Json // 10-3-2-1-0
  updatedAt  DateTime @updatedAt
}

// --- Week: a planning for a given week. ---
// A week can hold several plannings, distinguished by scope + owner:
//   - scope "familia": shared/public planning (ownerId null) — drives the dashboard.
//   - scope "personal" / "empresa": private planning owned by one member (ownerId set).
// Only the family planning uses the full set of relations (shopping, meal plan,
// events); private plannings stay lighter (north star + notes + activities).
model Week {
  id        String   @id @default(cuid())
  weekOf    DateTime @db.Date // Monday of that week
  scope     String   @default("familia") // familia | personal | empresa
  notes     String? // e.g. "qué nos descarriló"
  northStar String? // the north-star phrase recalled that Sunday
  createdAt DateTime @default(now())

  familyId String?
  family   Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)
  ownerId  String? // null for the shared family planning
  owner    User?   @relation("OwnedWeeks", fields: [ownerId], references: [id], onDelete: Cascade)

  shoppingItems ShoppingItem[]
  activities    Activity[]
  mealPlan      MealPlan?
  events        Event[]

  @@unique([familyId, ownerId, scope, weekOf])
  @@index([weekOf])
  @@index([ownerId, scope])
}

// --- Item on a week's shopping list. ---
model ShoppingItem {
  id      String  @id @default(cuid())
  weekId  String
  week    Week    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  name    String
  qty     String?
  aisle   String? // aisle / category
  checked Boolean @default(false)
  source  String  @default("manual") // "manual" | "receta"
}

// --- Activity / task of the week (workout, Wednesday out, clear tasks). ---
model Activity {
  id     String   @id @default(cuid())
  weekId String
  week   Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  day    Int // 0=Monday .. 6=Sunday
  title  String
  time   String? // "what has no time slot does not happen"
  who    String? // "Guille" / "China" / "ambos"
  type   String   @default("tarea") // tarea | entreno | conexion | social
  done   Boolean  @default(false)
}

// --- Recipe bank (1-2-12 system). They are approved and tagged. ---
model Recipe {
  id        String   @id @default(cuid())
  name      String
  source    String   @default("recetario 1-2-12")
  approved  Boolean  @default(false)
  proteinG  Int? // grams of protein per serving
  tags      String[] // ["sin-lacteos", "licuado", ...]
  prepStyle String   @default("full") // minimalist | batch | full
  isShake   Boolean  @default(false) // the "1": shake
  notes     String?
  createdAt DateTime @default(now())

  asShake MealPlanDay[] @relation("ShakeRecipe")
  asMeal1 MealPlanDay[] @relation("Meal1Recipe")
  asMeal2 MealPlanDay[] @relation("Meal2Recipe")

  @@index([approved])
}

// --- Meal plan for a week (shake + 2 meals/day). ---
model MealPlan {
  id     String        @id @default(cuid())
  weekId String        @unique
  week   Week          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  days   MealPlanDay[]
}

model MealPlanDay {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  day        Int // 0=Monday .. 6=Sunday

  shakeId String?
  shake   Recipe? @relation("ShakeRecipe", fields: [shakeId], references: [id])
  meal1Id String?
  meal1   Recipe? @relation("Meal1Recipe", fields: [meal1Id], references: [id])
  meal2Id String?
  meal2   Recipe? @relation("Meal2Recipe", fields: [meal2Id], references: [id])

  @@unique([mealPlanId, day])
}

// --- Social events/outings/appointments, with the plan decided IN ADVANCE (cold). ---
model Event {
  id       String    @id @default(cuid())
  weekId   String?
  week     Week?     @relation(fields: [weekId], references: [id], onDelete: SetNull)
  date     DateTime  @db.Date
  type     String    @default("social") // salida | social | cita-fertilidad
  place    String?
  invitees String[]
  plan     String? // the cold decision, e.g. "vamos pero no tomamos, nos vamos a las 9"
}

// --- Plan bank: cheap outings so the weekend does not end up blank. ---
model PlanIdea {
  id       String  @id @default(cuid())
  title    String
  category String  @default("salida") // parque | rio | salida | conexion
  cost     String  @default("gratis")
  notes    String?
  favorite Boolean @default(false)
}

// --- "No" script: replies already decided in advance (cold). ---
model NoScript {
  id      String @id @default(cuid())
  trigger String // e.g. "te ofrecen cerveza"
  reply   String // the decided reply
  order   Int    @default(0)
}

// --- Reminders (v2: backed by Google Calendar). ---
model Reminder {
  id             String  @id @default(cuid())
  kind           String // planning-viernes | planning-domingo | pastillas | agua
  label          String
  schedule       String // RRULE
  calendarBacked Boolean @default(false)
  active         Boolean @default(true)
}

# --- Base de datos (Neon en producción) ---
# En Vercel: pegá aquí la connection string de Neon (con ?sslmode=require).
# En local: apunta a tu Postgres de desarrollo.
DATABASE_URL="postgresql://usuario:password@host/familyso?sslmode=require"

# --- Auth.js ---
# Generá uno con: openssl rand -base64 32
AUTH_SECRET="cambiame-por-un-secreto-largo"

# --- Chat con Claude ---
# Tu API key de Anthropic (console.anthropic.com). Sin esto el chat queda deshabilitado.
ANTHROPIC_API_KEY=""

# --- Servidor MCP ---
# Token simple para que Claude (u otro cliente MCP) acceda a los datos de family-so.
MCP_TOKEN=""

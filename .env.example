# --- Database (Neon in production) ---
# In Vercel: paste the Neon connection string (with ?sslmode=require).
# Locally: point it at your dev Postgres.
DATABASE_URL="postgresql://user:password@host/familyso?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-secret"

# --- Google Workspace sign-in (Google-only) ---
# Create an OAuth 2.0 Client (Web application) in Google Cloud, enable the
# Google Calendar API, and add the redirect URIs:
#   http://localhost:3000/api/auth/callback/google   (local)
#   https://<your-vercel-domain>/api/auth/callback/google   (production)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Who may sign in. Set the two Workspace emails (comma-separated) and/or a domain.
ALLOWED_EMAILS="guille@scalater.com,china@scalater.com"
ALLOWED_GOOGLE_DOMAIN="scalater.com"

# Map each person to their Google email so individual data (habits/weight) links up.
GUILLE_EMAIL="guille@scalater.com"
CHINA_EMAIL="china@scalater.com"

# Time zone for timed/recurring calendar events (IANA name).
APP_TIMEZONE="America/Mexico_City"

# --- Claude chat ---
# Anthropic API key (console.anthropic.com). Without it the chat is disabled.
ANTHROPIC_API_KEY=""

# --- MCP server ---
# Simple token so Claude (or another MCP client) can reach family-so data.
MCP_TOKEN=""
